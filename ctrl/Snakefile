"""Snakefile

Top-level Snakemake orchestration for MitoPipeline.
"""

from pathlib import Path

from mitopipeline.config.runtime_manifest import (
    prepare_runtime_manifest,
)

OUTPUT_ROOT_VALUE = config.get(
    "output_root"
)

if not OUTPUT_ROOT_VALUE:
    raise ValueError(
        "'output_root' is required in the pipeline config."
    )

JOB_ID = config.get(
    "job_id"
)

if not JOB_ID:
    raise ValueError(
        "'job_id' is required in the resolved pipeline config."
    )

SOURCE_MANIFEST = config.get(
    "manifest"
)

INPUT_DIRECTORY = config.get(
    "input_directory"
)

if not SOURCE_MANIFEST and not INPUT_DIRECTORY:
    raise ValueError(
        "Provide either 'manifest' or 'input_directory'."
    )


OUTPUT_ROOT = Path(
    OUTPUT_ROOT_VALUE
)

JOB_DIR = (
    OUTPUT_ROOT
    / JOB_ID
)

STAGES = config.get(
    "stages",
    {},
)

RUNTIME_MANIFEST_PATH = (
    JOB_DIR
    / "metadata"
    / "runtime_manifest.tsv"
)

SAMPLE_TABLE = prepare_runtime_manifest(
    output_path=RUNTIME_MANIFEST_PATH,
    source_manifest=SOURCE_MANIFEST,
    input_directory=INPUT_DIRECTORY,
    validate_files=config.get(
        "validate_input_files",
        True,
    ),
)

SAMPLES = SAMPLE_TABLE.index.tolist()

def stage_enabled(
        stage_name: str,
) -> bool:
    """Return whether a requested output stage is enabled."""
    return bool(
        STAGES.get(
            stage_name,
            False,
        )
    )


def sample_targets(
        directory: str,
        filename: str,
) -> list[str]:
    """Expand one sample-level output path for every sample."""
    return expand(
        str(
            JOB_DIR
            / directory
            / filename
        ),
        sample=SAMPLES,
    )


def validate_stage_configuration() -> None:
    """Validate relationships between requested output stages."""
    if stage_enabled(
        "pdf_export"
    ) and not stage_enabled(
        "reporting"
    ):
        raise ValueError(
            "'pdf_export' requires 'reporting' to be enabled."
        )


def enabled_targets() -> list[str]:
    """Return final targets requested by the stage configuration."""
    targets: list[str] = []

    if stage_enabled(
        "qc_raw"
    ):
        targets.extend(
            sample_targets(
                directory="qc/raw",
                filename="{sample}.qc.raw.done",
            )
        )

    if stage_enabled(
        "trimming"
    ):
        targets.extend(
            sample_targets(
                directory="trimming",
                filename="{sample}.trimming.done",
            )
        )

    if stage_enabled(
        "qc_trimmed"
    ):
        targets.extend(
            sample_targets(
                directory="qc/trimmed",
                filename="{sample}.qc.trimmed.done",
            )
        )

    if stage_enabled(
        "assembly"
    ):
        targets.extend(
            sample_targets(
                directory="assembly",
                filename="{sample}.assembly.done",
            )
        )

    if stage_enabled(
        "annotation"
    ):
        targets.extend(
            sample_targets(
                directory="annotation",
                filename="{sample}.annotation.done",
            )
        )

    if stage_enabled(
        "visualization"
    ):
        targets.extend(
            sample_targets(
                directory="visualization",
                filename="{sample}.visualization.done",
            )
        )

    if stage_enabled(
        "phylogeny"
    ):
        targets.extend(
            sample_targets(
                directory="phylogeny/figures",
                filename="{sample}.phylogeny.done",
            )
        )

    if stage_enabled(
        "reporting"
    ):
        targets.extend(
            sample_targets(
                directory="reporting",
                filename="{sample}.report.md",
            )
        )

        targets.append(
            str(
                JOB_DIR
                / "reporting"
                / "run_report.md"
            )
        )

    if stage_enabled(
        "pdf_export"
    ):
        targets.extend(
            sample_targets(
                directory="reporting",
                filename="{sample}.report.pdf",
            )
        )

        targets.append(
            str(
                JOB_DIR
                / "reporting"
                / "run_report.pdf"
            )
        )

    if stage_enabled(
        "sra_archival"
    ):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "sra"
                / "sra_metadata.tsv"
            )
        )

    if stage_enabled(
        "biosample_archival"
    ):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "biosample"
                / "biosample_metadata.tsv"
            )
        )
    if stage_enabled(
        "mitogenome_archival"
    ):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "mitogenomes"
                / "mitogenome_metadata.tsv"
            )
        )
    if stage_enabled(
        "archival_validation"
    ):
        targets.extend(
            [
                str(
                    JOB_DIR
                    / "submission"
                    / "validation_summary.tsv"
                ),
                str(
                    JOB_DIR
                    / "submission"
                    / "validation_report.md"
                ),
            ]
        )
    return targets


validate_stage_configuration()

ENABLED_TARGETS = enabled_targets()

rule all:
    """Produce all configured pipeline outputs."""

    input:
        ENABLED_TARGETS

include: "rules/qc.raw.smk"
include: "rules/trimming.smk"
include: "rules/qc.trimmed.smk"

include: "rules/getorganelle_config.smk"
include: "rules/assembly.smk"

include: "rules/mitos2_config.smk"
include: "rules/annotation.smk"

include: "rules/visualization.smk"

include: "rules/blast_config.smk"
include: "rules/blast.smk"
include: "rules/blast_hits.smk"
include: "rules/alignment_dataset.smk"
include: "rules/phylogeny.smk"

include: "rules/reporting.smk"
include: "rules/report_pdf.smk"

include: "rules/sra_archival.smk"
include: "rules/biosample_archival.smk"
include: "rules/mitogenome_archival.smk"
include: "rules/archival_validation.smk"