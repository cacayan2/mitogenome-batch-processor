"""Snakefile

Top-level Snakemake orchestration for MitoPipeline.

This Snakefile consumes the launcher-generated runtime manifest. Normal
execution should use `python -m mitopipeline.launcher.pipeline_launcher`.
"""

from pathlib import Path

import pandas as pd

PROJECT_ROOT = Path(workflow.basedir).parent.resolve()
SRC_DIR = PROJECT_ROOT / "src"

shell.prefix(
    f"export PYTHONPATH='{SRC_DIR}:$PYTHONPATH'; "
)

OUTPUT_ROOT_VALUE = config.get(
    "output_root"
)

if not OUTPUT_ROOT_VALUE:
    raise ValueError(
        "'output_root' is required in the pipeline config."
    )

JOB_ID = config.get(
    "job_id"
)

if not JOB_ID:
    raise ValueError(
        "'job_id' is required in the runtime config. "
        "Use the pipeline launcher to create a runtime config."
    )

OUTPUT_ROOT = Path(
    OUTPUT_ROOT_VALUE
)

JOB_DIR = (
    OUTPUT_ROOT
    / JOB_ID
)

STAGES = config.get(
    "stages",
    {},
)

RUNTIME_MANIFEST_PATH = Path(
    config.get(
        "runtime_manifest",
        config.get(
            "manifest",
            "",
        ),
    )
).expanduser().resolve()

if not RUNTIME_MANIFEST_PATH.exists():
    raise FileNotFoundError(
        f"Runtime manifest not found: {RUNTIME_MANIFEST_PATH}"
    )

SAMPLE_TABLE = pd.read_csv(
    RUNTIME_MANIFEST_PATH,
    sep="\t",
    dtype=str,
    keep_default_na=False,
)

if "sample_id" not in SAMPLE_TABLE.columns:
    raise ValueError(
        "Runtime manifest must include a sample_id column."
    )

SAMPLE_TABLE = SAMPLE_TABLE.set_index(
    "sample_id",
    drop=False,
)

SAMPLES = SAMPLE_TABLE.index.tolist()


def stage_enabled(
        stage_name: str,
) -> bool:
    """Return whether a requested output stage is enabled."""
    return bool(
        STAGES.get(
            stage_name,
            False,
        )
    )


def sample_targets(
        directory: str,
        filename: str,
) -> list[str]:
    """Expand one sample-level target for every sample."""
    return expand(
        str(
            JOB_DIR
            / directory
            / filename
        ),
        sample=SAMPLES,
    )


def validate_stage_configuration() -> None:
    """Validate relationships between requested output stages."""
    if stage_enabled(
        "pdf_export"
    ) and not stage_enabled(
        "reporting"
    ):
        raise ValueError(
            "'pdf_export' requires 'reporting' to be enabled."
        )

    if stage_enabled(
        "table2asn_validation"
    ) and not stage_enabled(
        "mitogenome_archival"
    ):
        raise ValueError(
            "'table2asn_validation' requires "
            "'mitogenome_archival' to be enabled."
        )


def enabled_targets() -> list[str]:
    """Return final targets requested by stage configuration."""
    targets: list[str] = []

    if stage_enabled("qc_raw"):
        targets.extend(
            sample_targets(
                "qc/raw",
                "{sample}.qc.raw.done",
            )
        )

    if stage_enabled("trimming"):
        targets.extend(
            sample_targets(
                "trimming",
                "{sample}.trimming.done",
            )
        )

    if stage_enabled("qc_trimmed"):
        targets.extend(
            sample_targets(
                "qc/trimmed",
                "{sample}.qc.trimmed.done",
            )
        )

    if stage_enabled("assembly"):
        targets.extend(
            sample_targets(
                "assembly",
                "{sample}.assembly.done",
            )
        )

    if stage_enabled("annotation"):
        targets.extend(
            sample_targets(
                "annotation",
                "{sample}.annotation.done",
            )
        )

    if stage_enabled("visualization"):
        targets.extend(
            sample_targets(
                "visualization",
                "{sample}.visualization.done",
            )
        )

    if stage_enabled("phylogeny"):
        targets.extend(
            sample_targets(
                "phylogeny/figures",
                "{sample}.phylogeny.done",
            )
        )

    if stage_enabled("reporting"):
        targets.extend(
            sample_targets(
                "reporting",
                "{sample}.report.md",
            )
        )
        targets.append(
            str(
                JOB_DIR
                / "reporting"
                / "run_report.md"
            )
        )

    if stage_enabled("pdf_export"):
        targets.extend(
            sample_targets(
                "reporting",
                "{sample}.report.pdf",
            )
        )
        targets.append(
            str(
                JOB_DIR
                / "reporting"
                / "run_report.pdf"
            )
        )

    if stage_enabled("sra_archival"):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "sra"
                / "sra_metadata.tsv"
            )
        )

    if stage_enabled("biosample_archival"):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "biosample"
                / "biosample_metadata.tsv"
            )
        )

    if stage_enabled("mitogenome_archival"):
        targets.append(
            str(
                JOB_DIR
                / "submission"
                / "mitogenomes"
                / "mitogenome_metadata.tsv"
            )
        )

    if stage_enabled("archival_validation"):
        targets.extend(
            [
                str(
                    JOB_DIR
                    / "submission"
                    / "validation_summary.tsv"
                ),
                str(
                    JOB_DIR
                    / "submission"
                    / "validation_report.md"
                ),
            ]
        )

    if stage_enabled("table2asn_validation"):
        targets.extend(
            [
                str(
                    JOB_DIR
                    / "submission"
                    / "table2asn"
                    / "validation_summary.tsv"
                ),
                str(
                    JOB_DIR
                    / "submission"
                    / "table2asn"
                    / "validation_summary.md"
                ),
            ]
        )

    return targets


validate_stage_configuration()

ENABLED_TARGETS = enabled_targets()


rule all:
    """Produce all configured pipeline outputs."""

    input:
        ENABLED_TARGETS


include: "rules/qc.raw.smk"
include: "rules/trimming.smk"
include: "rules/qc.trimmed.smk"

include: "rules/getorganelle_config.smk"
include: "rules/assembly.smk"

include: "rules/mitos2_config.smk"
include: "rules/annotation.smk"

include: "rules/visualization.smk"

include: "rules/blast_config.smk"
include: "rules/blast.smk"
include: "rules/blast_hits.smk"
include: "rules/alignment_dataset.smk"
include: "rules/phylogeny.smk"

include: "rules/reporting.smk"
include: "rules/report_pdf.smk"

include: "rules/sra_archival.smk"
include: "rules/biosample_archival.smk"
include: "rules/mitogenome_archival.smk"
include: "rules/archival_validation.smk"
include: "rules/table2asn_validation.smk"
