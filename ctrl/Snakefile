"""Snakefile

This file contains the rule for running the overall Snakemake orchestration.
"""

# Imports
import pandas as pd
from pathlib import Path

# Reads the configuration file and specifies appropriate directories.
OUTPUT_ROOT = Path(config["output_root"])
JOB_ID = config["job_id"]
JOB_DIR = OUTPUT_ROOT / JOB_ID

# Obtaining the stages from the configuration file.
STAGES = config.get("stages", {})

# Reading the runtime sample manifest.
MANIFEST_PATH = Path(config["manifest"])
SAMPLE_TABLE = pd.read_csv(MANIFEST_PATH, sep="\t").set_index("sample_id")
SAMPLES = SAMPLE_TABLE.index.tolist()


def stage_enabled(stage_name: str) -> bool:
    """Return True if the stage is enabled."""

    return STAGES.get(stage_name, False)


def enabled_targets() -> list:
    """Return final workflow targets for enabled stages."""

    targets = []

    if stage_enabled("qc_raw"):
        targets.extend(
            expand(str(JOB_DIR / "qc" / "raw" / "{sample}.qc.raw.done"), sample=SAMPLES)
        )
    if stage_enabled("trimming"):
        targets.extend(
            expand(str(JOB_DIR / "trimming" / "{sample}.trimming.done"), sample=SAMPLES)
        )
    if stage_enabled("qc_trimmed"):
        targets.extend(
            expand(str(JOB_DIR / "qc" / "trimmed" / "{sample}.qc.trimmed.done"), sample=SAMPLES)
        )
    if stage_enabled("assembly"):
        targets.extend(
            expand(str(JOB_DIR / "assembly" / "{sample}.assembly.done"), sample=SAMPLES)
        )
    if stage_enabled("annotation"):
        targets.extend(
            expand(str(JOB_DIR / "annotation" / "{sample}.annotation.done"), sample=SAMPLES)
        )
    if stage_enabled("phylogeny"):
        targets.extend(
            expand(str(JOB_DIR / "phylogeny" / "blast" / "{sample}.top_hits.done"), sample=SAMPLES)
        )
    if stage_enabled("reporting"):
        targets.extend(
            expand(str(JOB_DIR / "reporting" / "{sample}.report.md"), sample=SAMPLES)
        )
    return targets


ENABLED_TARGETS = enabled_targets()

rule all:
    """Run enabled workflow stages."""
    input:
        ENABLED_TARGETS

# Include rule files conditionally.
if stage_enabled("qc_raw"):
    include: "rules/qc.raw.smk"

if stage_enabled("trimming"):
    include: "rules/trimming.smk"

if stage_enabled("qc_trimmed"):
    include: "rules/qc.trimmed.smk"

if stage_enabled("assembly"):
    include: "rules/getorganelle_config.smk"
    include: "rules/assembly.smk"

if stage_enabled("annotation"):
    include: "rules/mitos2_config.smk"
    include: "rules/annotation.smk"
    
if stage_enabled("phylogeny"):
    include: "rules/blast_config.smk"
    include: "rules/blast.smk"
    include: "rules/blast_hits.smk"

if stage_enabled("reporting"):
    include: "rules/reporting.smk"